# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files – local overrides stay private; production public vars are committed
.env.local
.env*.local
# .env.production is committed so Vercel picks up NEXT_PUBLIC_* at build time
# (contains only anon/public keys — never put service role keys here)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
